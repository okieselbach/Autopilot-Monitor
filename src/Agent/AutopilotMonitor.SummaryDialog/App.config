<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <runtime>
    <!-- Allow WPF to render even when no display devices are detected or the window station
         appears non-interactive. Required for CreateProcessAsUser from SYSTEM during Autopilot
         enrollment while the Hello screen is still active on the user's desktop. Without these
         switches, wpfgfx DLL init fails with 0x8007045A (ERROR_DLL_INIT_FAILED). -->
    <AppContextSwitchOverrides value="Switch.System.Windows.Media.ShouldRenderEvenWhenNoDisplayDevicesAreAvailable=true;Switch.System.Windows.Media.ShouldNotRenderInNonInteractiveWindowStation=false"/>
  </runtime>
</configuration>
