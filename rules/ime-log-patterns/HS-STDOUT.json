{
  "$schema": "../schema/ime-log-pattern.schema.json",
  "patternId": "HS-STDOUT",
  "category": "always",
  "pattern": "\\[HS\\] std output = (?<output>.*)",
  "action": "scriptOutput",
  "parameters": { "scriptType": "remediation", "outputType": "stdout" },
  "description": "Captures standard output (stdout) from a remediation script execution.",
  "enabled": true
}
