{
  "$schema": "../schema/ime-log-pattern.schema.json",
  "patternId": "HS-STDERR",
  "category": "always",
  "pattern": "\\[HS\\] err output = (?<output>.*)",
  "action": "scriptOutput",
  "parameters": { "scriptType": "remediation", "outputType": "stderr" },
  "description": "Captures standard error output (stderr) from a remediation script execution.",
  "enabled": true
}
