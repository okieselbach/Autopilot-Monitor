{
  "$schema": "../schema/ime-log-pattern.schema.json",
  "patternId": "IME-EXITCODE",
  "category": "currentPhase",
  "pattern": "\\[Win32App\\] lpExitCode (?<exitCode>-?\\d+)$",
  "action": "captureExitCode",
  "parameters": {
    "useCurrentApp": "true"
  },
  "description": "Captures the installer exit code (lpExitCode) for the current app.",
  "enabled": true
}
