{
  "$schema": "../schema/ime-log-pattern.schema.json",
  "patternId": "PS-SCRIPT-GENERATED",
  "category": "always",
  "pattern": "Script file C:\\\\.*\\\\Policies\\\\Scripts\\\\[a-z0-9\\-]+_(?<id>[a-z0-9]{8}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{12})\\.ps1 is generated",
  "action": "scriptStarted",
  "parameters": { "scriptType": "platform" },
  "description": "Detects when a platform PowerShell script file is generated by IME. Captures the PolicyId from the script file path.",
  "enabled": true
}
